spring:
  datasource:
    url: jdbc:postgresql://<host>:<port>/defaultdb?sslmode=require
    username: <username>
    password: ${DB_PASSWORD}
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect

server:
  port: 8048

jwt:
  secret: ${JWT_SECRET}
  expiration-ms: 86400000

