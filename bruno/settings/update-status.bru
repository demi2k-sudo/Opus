meta {
  name: Update Status
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/zones/{{zoneId}}/settings/statuses/{{statusId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "In Progress Edited",
    "color": "#112233",
    "isInitial": false,
    "isFinal": false
  }
}
