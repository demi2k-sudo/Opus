meta {
  name: Create Type
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/zones/{{zoneId}}/settings/types
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "STORY",
    "icon": "story-icon"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("typeId", res.body.id);
  }
}
